build['
mkdir -p /usr/bin/cydramanager/simplewc
meson setup -Dxwayland=enabled --prefix=/usr/bin/cydramanager/simplewc build
ninja -C build -j/#PROC#/
']

install['
ninja -C build install
mkdir -p /usr/bin/cydramanager-binaries

[ -d /usr/bin/cydramanager/simplewc/bin ] && find /usr/bin/cydramanager/simplewc/bin -maxdepth 1 -type f -executable -exec ln -sf {} /usr/bin/cydramanager-binaries/bin/ \;
[ -d /usr/bin/cydramanager/simplewc/lib ] && mkdir -p /usr/bin/cydramanager-binaries/lib && find /usr/bin/cydramanager/simplewc/lib -maxdepth 1 -type f -exec ln -sf {} /usr/bin/cydramanager-binaries/lib/ \;
[ -d /usr/bin/cydramanager/simplewc/include ] && mkdir -p /usr/bin/cydramanager-binaries/include && find /usr/bin/cydramanager/simplewc/include -maxdepth 1 -type f -exec ln -sf {} /usr/bin/cydramanager-binaries/include/ \;
[ -d /usr/bin/cydramanager/simplewc/share ] && mkdir -p /usr/bin/cydramanager-binaries/share && find /usr/bin/cydramanager/simplewc/share -maxdepth 1 -type f -exec ln -sf {} /usr/bin/cydramanager-binaries/share/ \;
']

dependency['
']

download['
https://github.com/kcirick/simplewc/archive/refs/tags/v0.4.tar.gz
']
