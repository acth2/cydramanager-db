build['
sed -i -e 's/GROUP="render"/GROUP="video"/' -e 's/GROUP="sgx", //' rules.d/50-udev-default.rules.in
mkdir build
cd build
meson setup .. --prefix=/usr --buildtype=release -D default-dnssec=no -D firstboot=false -D install-tests=false -D ldconfig=false -D man=auto -D sysusers=false -D rpmmacrosdir=no -D homed=disabled -D mode=release -D pam=enabled -D pamconfdir=/etc/pam.d -D dev-kvm-mode=0660 -D nobody-group=nogroup -D sysupdate=disabled -D ukify=disabled -D docdir=/usr/share/doc/systemd-259.1
ninja -j/#PROC#/
']

install['
ninja install
']

dependency['
linux-pam 1.7.2
']

download['
https://github.com/systemd/systemd/archive/v259.1/systemd-259.1.tar.gz
']
